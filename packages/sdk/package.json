{
  "name": "@webbios/sdk",
  "version": "1.0.0",
  "description": "The official WebbiOS JavaScript SDK",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.mjs",
      "require": "./dist/schemas/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts src/schemas/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/server.ts src/schemas/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/"
  },
  "dependencies": {
    "hono": "^4.2.0",
    "ulidx": "^2.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.1",
    "tsup": "^8.0.2",
    "typescript": "^5.2.2"
  }
}

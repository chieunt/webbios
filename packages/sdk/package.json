{
  "name": "@webbios/sdk",
  "version": "1.0.0",
  "description": "The official WebbiOS JavaScript SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
